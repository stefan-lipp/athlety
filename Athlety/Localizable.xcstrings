    "Apply custom event filters to only show events that match your preferences." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wende eigene Suchfilter an, um nur Wettkämpfe anzuzeigen, die deinen Kriterien entsprechen."
